<nav aria-label="Page navigation example" class="d-flex justify-content-center my-5 col offset-1">
  <ul class="pagination">

    <li class="page-item">
      <a class="page-link disabled" href="#" aria-label="Previous">
        <span aria-hidden="true">&laquo;</span>
      </a>
    </li>

    <% for(let i=0;i < page ;i++) { %>
      <!-- pageCurrent es enviado desde el controlador con el valor del offset que se recibe -->
      <!-- En la condición se evalúa que si la pagina actual es igual a la multiplicación del limite que es 12 por la cantidad de pagina que se recorre con el FOR -->
      <li class="page-item <%= pageCurrent === (limit * i) && "active" %>">
        <a class="page-link"
          href="/productos?offset=<%= !offset ? limit * i : (offset + limit) * i %>&limit=<%= limit %>">
          <%= i + 1 %>
        </a>
      </li>
      <% } %>

        <li class="page-item">
          <a class="page-link" href="#" aria-label="Next">
            <span aria-hidden="true">&raquo;</span>
          </a>
        </li>
  </ul>
</nav>